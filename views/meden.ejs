<%- include("partials/header") %>

<section class="legend-page legend-abyss">
  <div class="container legend-shell">
    <div class="legend-grid">
      <div class="legend-poster-wrap abyss-glow">
        <div class="legend-poster">
          <div class="legend-coming-soon">Coming Soon</div>
          <div class="legend-placeholder">
            <div class="legend-placeholder-box">
              <div class="legend-placeholder-text">Meden Image Placeholder</div>
            </div>
          </div>
        </div>
      </div>

      <div class="legend-copy">
        <div class="legend-badges">
          <span class="legend-badge abyss">Abyss</span>
          <span class="legend-tier">Enemy Force</span>
        </div>

        <h1>Meden</h1>
        <p class="legend-role">Hostile Power</p>
        <p class="legend-lead">
          Meden represents the hostile force rising against survival, order, and human stability.
          Their threat is active, invasive, and relentless.
        </p>

        <div class="legend-actions">
          <a class="btn btn-primary" href="/">Return Home</a>
          <a class="btn btn-secondary" href="/characters/hades">View Hades</a>
        </div>

        <div class="legend-panels">
          <div class="legend-panel">
            <h2>Description</h2>
            <p>
              Rather than a passive danger, Meden functions like pressure embodied — predatory,
              destabilizing, and built to overwhelm.
            </p>

            <div class="legend-power-grid">
              <div class="legend-power-card"><h3>Pressure</h3><p>Forces panic and collapse.</p></div>
              <div class="legend-power-card"><h3>Predation</h3><p>Targets weakness without mercy.</p></div>
              <div class="legend-power-card"><h3>Persistence</h3><p>Does not easily retreat.</p></div>
              <div class="legend-power-card"><h3>Fear Spread</h3><p>Turns terror into a weapon.</p></div>
            </div>

            <div class="legend-quote">“Some enemies are not fought once. They are survived repeatedly.”</div>
          </div>

          <div class="legend-panel">
            <h2>Profile</h2>
            <div class="legend-profile">
              <div class="legend-row"><span class="legend-label">Faction</span><span class="legend-value">Abyss</span></div>
              <div class="legend-row"><span class="legend-label">Role</span><span class="legend-value">Hostile Power</span></div>
              <div class="legend-row"><span class="legend-label">Power Theme</span><span class="legend-value">Predation / Pressure / Fear</span></div>
              <div class="legend-row"><span class="legend-label">Visual</span><span class="legend-value">Image Coming Soon</span></div>
              <div class="legend-row"><span class="legend-label">Background</span><span class="legend-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>