<%- include("partials/header") %>

<section class="legend-page legend-storm">
  <div class="container legend-shell">
    <div class="legend-grid">
      <div class="legend-poster-wrap storm-glow">
        <div class="legend-poster">
          <div class="legend-coming-soon">Coming Soon</div>
          <div class="legend-placeholder">
            <div class="legend-placeholder-box">
              <div class="legend-placeholder-text">Donner Image Placeholder</div>
            </div>
          </div>
        </div>
      </div>

      <div class="legend-copy">
        <div class="legend-badges">
          <span class="legend-badge storm">Storm</span>
          <span class="legend-tier">Titanic</span>
        </div>

        <h1>Donner</h1>
        <p class="legend-role">Thunder Incarnate</p>
        <p class="legend-lead">
          Donner is the crash of heaven’s wrath, marching with thunder in his veins.
        </p>

        <div class="legend-actions">
          <a class="btn btn-primary" href="/">Return Home</a>
          <a class="btn btn-secondary" href="/characters/cerberus">View Cerberus</a>
        </div>

        <div class="legend-panels">
          <div class="legend-panel">
            <h2>Description</h2>
            <p>
              Donner is force made glorious and violent. He does not slip quietly into conflict.
              He announces himself through pressure, sound, and impact. When he enters battle,
              the atmosphere shifts and fear arrives before the first strike lands.
            </p>

            <div class="legend-power-grid">
              <div class="legend-power-card"><h3>Thunder Force</h3><p>Hits with catastrophic electrical power.</p></div>
              <div class="legend-power-card"><h3>Storm Dominion</h3><p>Commands pressure, sky, and violent weather.</p></div>
              <div class="legend-power-card"><h3>War Presence</h3><p>Overwhelms the battlefield with sheer intensity.</p></div>
              <div class="legend-power-card"><h3>Impact Strikes</h3><p>Each blow lands like divine judgment.</p></div>
            </div>

            <div class="legend-quote">“The sky does not warn. It answers.”</div>
          </div>

          <div class="legend-panel">
            <h2>Profile</h2>
            <div class="legend-profile">
              <div class="legend-row"><span class="legend-label">Faction</span><span class="legend-value">Storm</span></div>
              <div class="legend-row"><span class="legend-label">Role</span><span class="legend-value">Thunder Incarnate</span></div>
              <div class="legend-row"><span class="legend-label">Power Theme</span><span class="legend-value">Thunder / Force / Sky Wrath</span></div>
              <div class="legend-row"><span class="legend-label">Visual</span><span class="legend-value">Image Coming Soon</span></div>
              <div class="legend-row"><span class="legend-label">Background</span><span class="legend-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>