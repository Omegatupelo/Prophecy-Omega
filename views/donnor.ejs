<%- include("partials/header") %>

<section class="character-page ancient-theme">
  <div class="container character-page-inner">
    <div class="character-cinematic-grid">
      <div class="character-poster">
        <div class="poster-coming-soon">Coming Soon</div>
        <div class="poster-placeholder">
          <div class="poster-placeholder-box">
            <div class="poster-placeholder-text">Donnor Image Placeholder</div>
          </div>
        </div>
      </div>

      <div class="character-copy">
        <div class="faction-badges">
          <span class="faction-badge faction-ancient">Ancient Powers</span>
          <span class="power-badge">Thunder-Class</span>
        </div>

        <h1>Donner</h1>
        <p class="character-subrole">Voice of Thunder</p>
        <p class="character-lead">
          Donner moves with storm-command, impact, and old-world force. His energy is loud, immediate,
          and impossible to ignore.
        </p>

        <div class="character-panels">
          <div class="cinematic-panel">
            <h2>Description</h2>
            <p>
              He represents force in motion — thunder, shock, and the violent announcement of power.
            </p>

            <div class="power-list">
              <div class="power-item"><h3>Thunder Call</h3><p>Announces power with overwhelming force.</p></div>
              <div class="power-item"><h3>Impact</h3><p>Strikes with explosive pressure.</p></div>
              <div class="power-item"><h3>Storm Link</h3><p>Moves in sync with atmospheric violence.</p></div>
              <div class="power-item"><h3>Presence</h3><p>Turns fear into momentum.</p></div>
            </div>

            <div class="quote-panel">“Some powers whisper. Mine arrives with thunder.”</div>
          </div>

          <div class="cinematic-panel">
            <h2>Profile</h2>
            <div class="profile-list">
              <div class="profile-row"><span class="profile-label">Faction</span><span class="profile-value">Ancient Powers</span></div>
              <div class="profile-row"><span class="profile-label">Role</span><span class="profile-value">Voice of Thunder</span></div>
              <div class="profile-row"><span class="profile-label">Power Theme</span><span class="profile-value">Storm / Impact / Force</span></div>
              <div class="profile-row"><span class="profile-label">Visual</span><span class="profile-value">Image Coming Soon</span></div>
              <div class="profile-row"><span class="profile-label">Background</span><span class="profile-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>