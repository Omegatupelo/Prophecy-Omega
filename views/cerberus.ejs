<%- include("partials/header") %>

<section class="legend-page legend-ancient">
  <div class="container legend-shell">
    <div class="legend-grid">

      <!-- IMAGE SECTION -->
      <div class="legend-poster-wrap ancient-glow">
        <div class="legend-poster">
          <img src="/images/cerberus.jpg" class="legend-image" alt="Cerberus">
        </div>
      </div>

      <!-- TEXT CONTENT -->
      <div class="legend-copy">
        <div class="legend-badges">
          <span class="legend-badge ancient">Ancient Guardian</span>
          <span class="legend-tier">Mythic-Class</span>
        </div>

        <h1>Cerberus</h1>
        <p class="legend-role">Three-Headed Guardian</p>
        <p class="legend-lead">
          Cerberus is not just a beast of power, but a loyal, playful guardian whose three
          heads carry different moods, one body, and one fierce devotion to those he loves.
        </p>

        <div class="legend-actions">
          <a class="btn btn-primary" href="/">Return Home</a>
          <a class="btn btn-secondary" href="/characters/hades">View Hades</a>
        </div>

        <div class="legend-panels">

          <!-- DESCRIPTION -->
          <div class="legend-panel">
            <h2>Description</h2>
            <p>
              Cerberus carries one heart across three personalities. One head leans in for
              affection, one sits proudly with decorated softness, and one resists until
              comfort finally wins it over. Beneath the playful energy is a guardian spirit
              that will not abandon those it has chosen to protect.
            </p>

            <div class="legend-power-grid">
              <div class="legend-power-card">
                <h3>Loyalty</h3>
                <p>Protects family with unwavering devotion and instinct.</p>
              </div>
              <div class="legend-power-card">
                <h3>Guardian Instinct</h3>
                <p>Watches constantly and reacts the moment danger appears.</p>
              </div>
              <div class="legend-power-card">
                <h3>Threefold Nature</h3>
                <p>Each head shows a different personality, but all move as one.</p>
              </div>
              <div class="legend-power-card">
                <h3>Playful Strength</h3>
                <p>Carefree and affectionate until it is time to defend.</p>
              </div>
            </div>

            <div class="legend-quote">
              “Three heads. One heart.”
            </div>
          </div>

          <!-- PROFILE -->
          <div class="legend-panel">
            <h2>Profile</h2>
            <div class="legend-profile">
              <div class="legend-row">
                <span class="legend-label">Faction</span>
                <span class="legend-value">Ancient Guardian</span>
              </div>
              <div class="legend-row">
                <span class="legend-label">Role</span>
                <span class="legend-value">Three-Headed Protector</span>
              </div>
              <div class="legend-row">
                <span class="legend-label">Power Theme</span>
                <span class="legend-value">Loyalty / Protection / Playfulness</span>
              </div>
              <div class="legend-row">
                <span class="legend-label">Visual</span>
                <span class="legend-value">White Three-Headed Hound</span>
              </div>
              <div class="legend-row">
                <span class="legend-label">Background</span>
                <span class="legend-value">Golden Forest Guardian</span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>