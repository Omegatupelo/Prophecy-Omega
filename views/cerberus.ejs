<%- include("partials/header") %>

<section class="character-page heaven-theme">
  <div class="container character-page-inner">
    <div class="character-cinematic-grid">
      <div class="character-poster">
        <div class="poster-coming-soon">Coming Soon</div>
        <div class="poster-placeholder">
          <div class="poster-placeholder-box">
            <div class="poster-placeholder-text">Cerberus Image Placeholder</div>
          </div>
        </div>
      </div>

      <div class="character-copy">
        <div class="faction-badges">
          <span class="faction-badge faction-heaven">Heaven</span>
          <span class="power-badge">Guardian-Class</span>
        </div>

        <h1>Cerberus</h1>
        <p class="character-subrole">Guardian of the Gate</p>
        <p class="character-lead">
          Cerberus is a gatekeeper presence — relentless, alert, and absolute in duty.
          Nothing crosses the line without consequence.
        </p>

        <div class="character-panels">
          <div class="cinematic-panel">
            <h2>Description</h2>
            <p>
              A guardian force connected to boundary, judgment, and protection, Cerberus stands where passage
              becomes permission and intrusion becomes punishment.
            </p>

            <div class="power-list">
              <div class="power-item"><h3>Guard Duty</h3><p>Maintains sacred boundaries.</p></div>
              <div class="power-item"><h3>Judgment</h3><p>Responds instantly to violation.</p></div>
              <div class="power-item"><h3>Endurance</h3><p>Does not tire under pressure.</p></div>
              <div class="power-item"><h3>Dominance</h3><p>Projects control through presence.</p></div>
            </div>

            <div class="quote-panel">“The gate is not crossed. It is survived.”</div>
          </div>

          <div class="cinematic-panel">
            <h2>Profile</h2>
            <div class="profile-list">
              <div class="profile-row"><span class="profile-label">Faction</span><span class="profile-value">Heaven</span></div>
              <div class="profile-row"><span class="profile-label">Role</span><span class="profile-value">Guardian of the Gate</span></div>
              <div class="profile-row"><span class="profile-label">Power Theme</span><span class="profile-value">Protection / Judgment / Boundary</span></div>
              <div class="profile-row"><span class="profile-label">Visual</span><span class="profile-value">Image Coming Soon</span></div>
              <div class="profile-row"><span class="profile-label">Background</span><span class="profile-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>