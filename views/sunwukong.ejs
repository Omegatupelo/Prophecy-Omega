<%- include("partials/header") %>

<section class="character-page ancient-theme">
  <div class="container character-page-inner">
    <div class="character-cinematic-grid">
      <div class="character-poster">
        <div class="poster-coming-soon">Coming Soon</div>
        <div class="poster-placeholder">
          <div class="poster-placeholder-box">
            <div class="poster-placeholder-text">Shiva Image Placeholder</div>
          </div>
        </div>
      </div>

      <div class="character-copy">
        <div class="faction-badges">
          <span class="faction-badge faction-ancient">Ancient Powers</span>
          <span class="power-badge">Cosmic-Class</span>
        </div>

        <h1>Shiva</h1>
        <p class="character-subrole">Lord of Transformation</p>
        <p class="character-lead">
          Shiva embodies destruction, renewal, and cosmic force. His presence suggests that endings
          are never merely endings.
        </p>

        <div class="character-panels">
          <div class="cinematic-panel">
            <h2>Description</h2>
            <p>
              He represents transformation at the highest scale — the kind that destroys one age
              to make room for another.
            </p>

            <div class="power-list">
              <div class="power-item"><h3>Transformation</h3><p>Turns destruction into transition.</p></div>
              <div class="power-item"><h3>Cosmic Force</h3><p>Moves beyond ordinary battle logic.</p></div>
              <div class="power-item"><h3>Stillness</h3><p>Commands power without hurry.</p></div>
              <div class="power-item"><h3>Renewal</h3><p>Builds through ruin.</p></div>
            </div>

            <div class="quote-panel">“Some destruction is mercy in disguise.”</div>
          </div>

          <div class="cinematic-panel">
            <h2>Profile</h2>
            <div class="profile-list">
              <div class="profile-row"><span class="profile-label">Faction</span><span class="profile-value">Ancient Powers</span></div>
              <div class="profile-row"><span class="profile-label">Role</span><span class="profile-value">Lord of Transformation</span></div>
              <div class="profile-row"><span class="profile-label">Power Theme</span><span class="profile-value">Destruction / Renewal / Cosmic Force</span></div>
              <div class="profile-row"><span class="profile-label">Visual</span><span class="profile-value">Image Coming Soon</span></div>
              <div class="profile-row"><span class="profile-label">Background</span><span class="profile-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>