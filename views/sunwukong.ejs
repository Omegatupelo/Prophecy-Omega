<%- include("partials/header") %>

<section class="legend-page legend-celestial">
  <div class="container legend-shell">
    <div class="legend-grid">
      <div class="legend-poster-wrap celestial-glow">
        <div class="legend-poster">
          <div class="legend-coming-soon">Coming Soon</div>
          <div class="legend-placeholder">
            <div class="legend-placeholder-box">
              <div class="legend-placeholder-text">Sun Wukong Image Placeholder</div>
            </div>
          </div>
        </div>
      </div>

      <div class="legend-copy">
        <div class="legend-badges">
          <span class="legend-badge celestial">Celestial</span>
          <span class="legend-tier">Mythic</span>
        </div>

        <h1>Sun Wukong</h1>
        <p class="legend-role">The Monkey King</p>
        <p class="legend-lead">
          Sun Wukong is speed, rebellion, brilliance, and chaos forged into an unstoppable legend.
        </p>

        <div class="legend-actions">
          <a class="btn btn-primary" href="/">Return Home</a>
          <a class="btn btn-secondary" href="/characters/loki">View Loki</a>
        </div>

        <div class="legend-panels">
          <div class="legend-panel">
            <h2>Description</h2>
            <p>
              Sun Wukong storms the battlefield with swagger, unpredictability, and overwhelming force.
              He is not merely comic energy or mythic flair—he is disruption incarnate. He breaks rhythm,
              shatters fear, and refuses to let the laws of war define what he can become.
            </p>

            <div class="legend-power-grid">
              <div class="legend-power-card"><h3>Mythic Agility</h3><p>Moves faster than most enemies can react.</p></div>
              <div class="legend-power-card"><h3>Chaos Combat</h3><p>Turns unpredictability into battlefield advantage.</p></div>
              <div class="legend-power-card"><h3>Immense Strength</h3><p>Crushes resistance with legendary force.</p></div>
              <div class="legend-power-card"><h3>Rebel Spirit</h3><p>Refuses limits, fear, and submission.</p></div>
            </div>

            <div class="legend-quote">“The impossible usually starts when I smile.”</div>
          </div>

          <div class="legend-panel">
            <h2>Profile</h2>
            <div class="legend-profile">
              <div class="legend-row"><span class="legend-label">Faction</span><span class="legend-value">Celestial</span></div>
              <div class="legend-row"><span class="legend-label">Role</span><span class="legend-value">The Monkey King</span></div>
              <div class="legend-row"><span class="legend-label">Power Theme</span><span class="legend-value">Chaos / Speed / Strength</span></div>
              <div class="legend-row"><span class="legend-label">Visual</span><span class="legend-value">Image Coming Soon</span></div>
              <div class="legend-row"><span class="legend-label">Background</span><span class="legend-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>