<%- include("partials/header") %>

<section class="legend-page legend-heaven">
  <div class="container legend-shell">
    <div class="legend-grid">

      <!-- IMAGE SECTION -->
      <div class="legend-poster-wrap heaven-glow">
        <div class="legend-poster">
          <img src="/images/Hades.jpg" class="legend-image" alt="Hades">
        </div>
      </div>

      <!-- TEXT CONTENT -->
      <div class="legend-copy">
        <div class="legend-badges">
          <span class="legend-badge heaven">Heaven</span>
          <span class="legend-tier">Underworld-Class</span>
        </div>

        <h1>Hades</h1>
        <p class="legend-role">Lord of the Underworld</p>
        <p class="legend-lead">
          Hades carries silence, dominion, and dark order. His power feels ancient, heavy,
          and tied to the consequences beneath life itself.
        </p>

        <div class="legend-actions">
          <a class="btn btn-primary" href="/">Return Home</a>
        </div>

        <div class="legend-panels">

          <!-- DESCRIPTION -->
          <div class="legend-panel">
            <h2>Description</h2>
            <p>
              He does not move like panic. He moves like inevitability. Hades represents rule over shadow,
              consequence, and the unseen depths below order.
            </p>

            <div class="legend-power-grid">
              <div class="legend-power-card">
                <h3>Underworld Rule</h3>
                <p>Commands the realm beneath the veil.</p>
              </div>
              <div class="legend-power-card">
                <h3>Magic specialist</h3>
                <p>Dark manipulation and control.</p>
              </div>
              <div class="legend-power-card">
                <h3>Control</h3>
                <p>Rules with cold authority.</p>
              </div>
              <div class="legend-power-card">
                <h3>Finality</h3>
                <p>Turns endings into power.</p>
              </div>
            </div>

            <div class="legend-quote">
              “When I'm in class begin.”
            </div>
          </div>

          <!-- PROFILE -->
          <div class="legend-panel">
            <h2>Profile</h2>
            <div class="legend-profile">
              <div class="legend-row">
                <span class="legend-label">Faction</span>
                <span class="legend-value">Heaven</span>
              </div>
              <div class="legend-row">
                <span class="legend-label">Role</span>
                <span class="legend-value">overseer of the Underworld</span>
              </div>
              <div class="legend-row">
                <span class="legend-label">Power Theme</span>
                <span class="legend-value">Shadow / Dominion / Finality</span>
              </div>
              <div class="legend-row">
                <span class="legend-label">Visual</span>
                <span class="legend-value">loves fashion</span>
              </div>
              <div class="legend-row">
                <span class="legend-label">Background</span>
                <span class="legend-value">Runway of Power</span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>