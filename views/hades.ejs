<%- include("partials/header") %>

<section class="character-page abyss-theme">
  <div class="container character-page-inner">
    <div class="character-cinematic-grid">
      <div class="character-poster">
        <div class="poster-coming-soon">Coming Soon</div>
        <div class="poster-placeholder">
          <div class="poster-placeholder-box">
            <div class="poster-placeholder-text">Hades Image Placeholder</div>
          </div>
        </div>
      </div>

      <div class="character-copy">
        <div class="faction-badges">
          <span class="faction-badge faction-abyss">Abyss</span>
          <span class="power-badge">Underworld-Class</span>
        </div>

        <h1>Hades</h1>
        <p class="character-subrole">Lord of the Underworld</p>
        <p class="character-lead">
          Hades carries silence, dominion, and dark order. His power feels ancient, contained,
          and heavy with consequences.
        </p>

        <div class="character-panels">
          <div class="cinematic-panel">
            <h2>Description</h2>
            <p>
              He does not move like panic — he moves like inevitability. Hades represents rule over shadow,
              consequence, and the unseen depths below life.
            </p>

            <div class="power-list">
              <div class="power-item"><h3>Underworld Rule</h3><p>Commands the realm beneath the veil.</p></div>
              <div class="power-item"><h3>Shadow Weight</h3><p>Brings heaviness and dread.</p></div>
              <div class="power-item"><h3>Control</h3><p>Rules with cold authority.</p></div>
              <div class="power-item"><h3>Finality</h3><p>Turns endings into power.</p></div>
            </div>

            <div class="quote-panel">“Some thrones are not built in light.”</div>
          </div>

          <div class="cinematic-panel">
            <h2>Profile</h2>
            <div class="profile-list">
              <div class="profile-row"><span class="profile-label">Faction</span><span class="profile-value">Abyss</span></div>
              <div class="profile-row"><span class="profile-label">Role</span><span class="profile-value">Lord of the Underworld</span></div>
              <div class="profile-row"><span class="profile-label">Power Theme</span><span class="profile-value">Shadow / Dominion / Finality</span></div>
              <div class="profile-row"><span class="profile-label">Visual</span><span class="profile-value">Image Coming Soon</span></div>
              <div class="profile-row"><span class="profile-label">Background</span><span class="profile-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>