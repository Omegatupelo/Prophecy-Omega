<%- include("partials/header") %>

<section class="character-page heaven-theme">
  <div class="container character-page-inner">
    <div class="character-cinematic-grid">
      <div class="character-poster">
        <div class="poster-coming-soon">Coming Soon</div>
        <div class="poster-placeholder">
          <div class="poster-placeholder-box">
            <div class="poster-placeholder-text">Set Image Placeholder</div>
          </div>
        </div>
      </div>

      <div class="character-copy">
        <div class="faction-badges">
          <span class="faction-badge faction-heaven">Heaven</span>
          <span class="power-badge">Storm-Class</span>
        </div>

        <h1>Set</h1>
        <p class="character-subrole">God of Storms</p>
        <p class="character-lead">
          Set is living storm-force — impact, violence, and divine pressure wrapped in power.
          Every battlefield shifts when he enters.
        </p>

        <div class="character-panels">
          <div class="cinematic-panel">
            <h2>Description</h2>
            <p>
              He does not merely bring power. He brings atmospheric dominance, pressure, and storm-command.
            </p>

            <div class="power-list">
              <div class="power-item"><h3>Storm Rule</h3><p>Commands battlefield weather and force.</p></div>
              <div class="power-item"><h3>Impact</h3><p>Hits with overwhelming pressure.</p></div>
              <div class="power-item"><h3>Fear Presence</h3><p>Makes conflict feel larger instantly.</p></div>
              <div class="power-item"><h3>Command</h3><p>Moves like power already answered.</p></div>
            </div>

            <div class="quote-panel">“When the storm enters, the battle changes names.”</div>
          </div>

          <div class="cinematic-panel">
            <h2>Profile</h2>
            <div class="profile-list">
              <div class="profile-row"><span class="profile-label">Faction</span><span class="profile-value">Heaven</span></div>
              <div class="profile-row"><span class="profile-label">Role</span><span class="profile-value">God of Storms</span></div>
              <div class="profile-row"><span class="profile-label">Power Theme</span><span class="profile-value">Storm / Force / Pressure</span></div>
              <div class="profile-row"><span class="profile-label">Visual</span><span class="profile-value">Image Coming Soon</span></div>
              <div class="profile-row"><span class="profile-label">Background</span><span class="profile-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>