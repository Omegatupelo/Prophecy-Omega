<%- include("partials/header") %>

<section class="legend-page legend-heaven">
  <div class="container legend-shell">
    <div class="legend-grid">
      <div class="legend-poster-wrap heaven-glow">
        <div class="legend-poster">
          <div class="legend-coming-soon">Coming Soon</div>
          <div class="legend-placeholder">
            <div class="legend-placeholder-box">
              <div class="legend-placeholder-text">Set Image Placeholder</div>
            </div>
          </div>
        </div>
      </div>

      <div class="legend-copy">
        <div class="legend-badges">
          <span class="legend-badge heaven">Heaven</span>
          <span class="legend-tier">Storm-Class</span>
        </div>

        <h1>Set</h1>
        <p class="legend-role">God of Storms</p>
        <p class="legend-lead">
          Set is living storm-force — impact, violence, and divine pressure wrapped in power.
          Every battlefield shifts when he enters.
        </p>

        <div class="legend-actions">
          <a class="btn btn-primary" href="/">Return Home</a>
          <a class="btn btn-secondary" href="/characters/josiah">View Josiah</a>
        </div>

        <div class="legend-panels">
          <div class="legend-panel">
            <h2>Description</h2>
            <p>
              He does not merely bring power. He brings atmospheric dominance, pressure, and battlefield force.
            </p>

            <div class="legend-power-grid">
              <div class="legend-power-card"><h3>Storm Rule</h3><p>Commands battlefield weather and force.</p></div>
              <div class="legend-power-card"><h3>Impact</h3><p>Hits with overwhelming pressure.</p></div>
              <div class="legend-power-card"><h3>Fear Presence</h3><p>Makes conflict feel larger instantly.</p></div>
              <div class="legend-power-card"><h3>Command</h3><p>Moves like power already answered.</p></div>
            </div>

            <div class="legend-quote">“When the storm enters, the battle changes names.”</div>
          </div>

          <div class="legend-panel">
            <h2>Profile</h2>
            <div class="legend-profile">
              <div class="legend-row"><span class="legend-label">Faction</span><span class="legend-value">Heaven</span></div>
              <div class="legend-row"><span class="legend-label">Role</span><span class="legend-value">God of Storms</span></div>
              <div class="legend-row"><span class="legend-label">Power Theme</span><span class="legend-value">Storm / Force / Pressure</span></div>
              <div class="legend-row"><span class="legend-label">Visual</span><span class="legend-value">Image Coming Soon</span></div>
              <div class="legend-row"><span class="legend-label">Background</span><span class="legend-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>