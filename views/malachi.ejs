<%- include("partials/header") %>

<section class="character-page heaven-theme">
  <div class="container character-page-inner">
    <div class="character-cinematic-grid">
      <div class="character-poster">
        <div class="poster-coming-soon">Coming Soon</div>
        <div class="poster-placeholder">
          <div class="poster-placeholder-box">
            <div class="poster-placeholder-text">Malachi Image Placeholder</div>
          </div>
        </div>
      </div>

      <div class="character-copy">
        <div class="faction-badges">
          <span class="faction-badge faction-heaven">Heaven</span>
          <span class="power-badge">Messenger-Class</span>
        </div>

        <h1>Malachi</h1>
        <p class="character-subrole">Messenger of Fire</p>
        <p class="character-lead">
          Malachi moves with urgency, revelation, and the weight of a message that cannot be ignored.
          He is not merely present — he is sent.
        </p>

        <div class="character-panels">
          <div class="cinematic-panel">
            <h2>Description</h2>
            <p>
              In a world strained by prophecy and conflict, Malachi carries warning, purpose, and divine timing.
            </p>

            <div class="power-list">
              <div class="power-item"><h3>Message</h3><p>Delivers what must be spoken.</p></div>
              <div class="power-item"><h3>Fire</h3><p>Carries intensity and purification.</p></div>
              <div class="power-item"><h3>Urgency</h3><p>Moves at the speed of necessity.</p></div>
              <div class="power-item"><h3>Conviction</h3><p>Stands firm in mission.</p></div>
            </div>

            <div class="quote-panel">“Some words are not suggestions. They are summons.”</div>
          </div>

          <div class="cinematic-panel">
            <h2>Profile</h2>
            <div class="profile-list">
              <div class="profile-row"><span class="profile-label">Faction</span><span class="profile-value">Heaven</span></div>
              <div class="profile-row"><span class="profile-label">Role</span><span class="profile-value">Messenger of Fire</span></div>
              <div class="profile-row"><span class="profile-label">Power Theme</span><span class="profile-value">Mission / Warning / Fire</span></div>
              <div class="profile-row"><span class="profile-label">Visual</span><span class="profile-value">Image Coming Soon</span></div>
              <div class="profile-row"><span class="profile-label">Background</span><span class="profile-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>