<%- include("partials/header") %>

<section class="legend-page legend-heaven">
  <div class="container legend-shell">
    <div class="legend-grid">
      <div class="legend-poster-wrap heaven-glow">
        <div class="legend-poster">
          <div class="legend-coming-soon">Coming Soon</div>
          <div class="legend-placeholder">
            <div class="legend-placeholder-box">
              <div class="legend-placeholder-text">Malachi Image Placeholder</div>
            </div>
          </div>
        </div>
      </div>

      <div class="legend-copy">
        <div class="legend-badges">
          <span class="legend-badge heaven">Heaven</span>
          <span class="legend-tier">Messenger-Class</span>
        </div>

        <h1>Malachi</h1>
        <p class="legend-role">Messenger of Fire</p>
        <p class="legend-lead">
          Malachi moves with urgency, revelation, and the weight of a message that cannot be ignored.
          He is not merely present in prophecy — he is sent into it.
        </p>

        <div class="legend-actions">
          <a class="btn btn-primary" href="/">Return Home</a>
          <a class="btn btn-secondary" href="/characters/elijah">View Elijah</a>
        </div>

        <div class="legend-panels">
          <div class="legend-panel">
            <h2>Description</h2>
            <p>
              In a world collapsing under prophecy and war, Malachi carries warning, purpose, and the fire
              of divine timing. His role is not comfort — it is clarity.
            </p>

            <div class="legend-power-grid">
              <div class="legend-power-card">
                <h3>Message</h3>
                <p>Delivers what must be spoken without compromise.</p>
              </div>
              <div class="legend-power-card">
                <h3>Fire</h3>
                <p>Carries intensity, purification, and urgency.</p>
              </div>
              <div class="legend-power-card">
                <h3>Conviction</h3>
                <p>Moves with mission and refuses to fold.</p>
              </div>
              <div class="legend-power-card">
                <h3>Timing</h3>
                <p>Appears exactly when the message matters most.</p>
              </div>
            </div>

            <div class="legend-quote">“Some words are not advice. They are summons.”</div>
          </div>

          <div class="legend-panel">
            <h2>Profile</h2>
            <div class="legend-profile">
              <div class="legend-row"><span class="legend-label">Faction</span><span class="legend-value">Heaven</span></div>
              <div class="legend-row"><span class="legend-label">Role</span><span class="legend-value">Messenger of Fire</span></div>
              <div class="legend-row"><span class="legend-label">Power Theme</span><span class="legend-value">Mission / Warning / Fire</span></div>
              <div class="legend-row"><span class="legend-label">Visual</span><span class="legend-value">Image Coming Soon</span></div>
              <div class="legend-row"><span class="legend-label">Background</span><span class="legend-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>