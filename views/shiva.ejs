<%- include("partials/header") %>

<section class="legend-page legend-ancient">
  <div class="container legend-shell">
    <div class="legend-grid">
      <div class="legend-poster-wrap ancient-glow">
        <div class="legend-poster">
          <div class="legend-coming-soon">Coming Soon</div>
          <div class="legend-placeholder">
            <div class="legend-placeholder-box">
              <div class="legend-placeholder-text">Shiva Image Placeholder</div>
            </div>
          </div>
        </div>
      </div>

      <div class="legend-copy">
        <div class="legend-badges">
          <span class="legend-badge ancient">Ancient Powers</span>
          <span class="legend-tier">Cosmic-Class</span>
        </div>

        <h1>Shiva</h1>
        <p class="legend-role">Lord of Transformation</p>
        <p class="legend-lead">
          Shiva embodies destruction, renewal, and cosmic force. His presence suggests that endings
          are never merely endings.
        </p>

        <div class="legend-actions">
          <a class="btn btn-primary" href="/">Return Home</a>
          <a class="btn btn-secondary" href="/characters/sekhmet">View Sekhmet</a>
        </div>

        <div class="legend-panels">
          <div class="legend-panel">
            <h2>Description</h2>
            <p>
              He represents transformation at the highest scale — the kind that destroys one age
              to make room for another.
            </p>

            <div class="legend-power-grid">
              <div class="legend-power-card"><h3>Transformation</h3><p>Turns destruction into transition.</p></div>
              <div class="legend-power-card"><h3>Cosmic Force</h3><p>Moves beyond ordinary battle logic.</p></div>
              <div class="legend-power-card"><h3>Stillness</h3><p>Commands power without hurry.</p></div>
              <div class="legend-power-card"><h3>Renewal</h3><p>Builds through ruin.</p></div>
            </div>

            <div class="legend-quote">“Some destruction is mercy in disguise.”</div>
          </div>

          <div class="legend-panel">
            <h2>Profile</h2>
            <div class="legend-profile">
              <div class="legend-row"><span class="legend-label">Faction</span><span class="legend-value">Ancient Powers</span></div>
              <div class="legend-row"><span class="legend-label">Role</span><span class="legend-value">Lord of Transformation</span></div>
              <div class="legend-row"><span class="legend-label">Power Theme</span><span class="legend-value">Destruction / Renewal / Cosmic Force</span></div>
              <div class="legend-row"><span class="legend-label">Visual</span><span class="legend-value">Image Coming Soon</span></div>
              <div class="legend-row"><span class="legend-label">Background</span><span class="legend-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>