<%- include("partials/header") %>

<section class="character-hero abyss-glow">
  <div class="container character-shell">
    <div class="character-top">
      <div class="character-portrait-wrap">
        <div class="character-portrait">
          <img src="/images/cover.png" alt="Apollyon" />
        </div>
      </div>

      <div class="character-meta">
        <div class="faction-row">
          <span class="badge badge-abyss">The Abyss</span>
          <span class="badge">Destruction Class</span>
        </div>

        <h1>Apollyon</h1>
        <p class="character-subtitle">Lord of Destruction</p>
        <div class="power-rank">Power Tier: Cataclysmic</div>

        <p class="character-intro">
          Apollyon is terror, ruin, and violent authority wrapped in living judgment. His very
          presence changes the atmosphere of conflict and deepens the horror of the war.
        </p>

        <div class="character-actions">
          <a class="btn btn-primary" href="/">Return Home</a>
          <a class="btn btn-secondary" href="/characters/loki">View Loki</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="character-panel-section">
  <div class="container panel-grid">
    <div class="elite-panel">
      <h2>Lore</h2>
      <p class="lore-text">
        Apollyon does not merely appear in the conflict — he invades it. He represents the hunger
        of the abyss, the release of devastation, and the violence waiting beneath restraint.
      </p>

      <div class="power-grid">
        <div class="power-card power-abyss">
          <h3>Destruction Aura</h3>
          <p>His presence alone signals devastation and dread.</p>
        </div>

        <div class="power-card power-abyss">
          <h3>Abyssal Dominion</h3>
          <p>Commands fear and power tied to the darkness below order.</p>
        </div>

        <div class="power-card power-abyss">
          <h3>Judgment Force</h3>
          <p>Moves like punishment unleashed without mercy.</p>
        </div>

        <div class="power-card power-abyss">
          <h3>War Pressure</h3>
          <p>Escalates every battlefield he enters.</p>
        </div>
      </div>

      <div class="quote-box">
        “He does not walk into war. War bends darker when he arrives.”
      </div>
    </div>

    <div class="elite-panel">
      <h2>Profile</h2>

      <div class="stats-list">
        <div class="stat-row">
          <span class="stat-label">Faction</span>
          <span class="stat-value">The Abyss</span>
        </div>

        <div class="stat-row">
          <span class="stat-label">Role</span>
          <span class="stat-value">Lord of Destruction</span>
        </div>

        <div class="stat-row">
          <span class="stat-label">Primary Theme</span>
          <span class="stat-value">Judgment / Ruin / Terror</span>
        </div>

        <div class="stat-row">
          <span class="stat-label">Threat Level</span>
          <span class="stat-value">Cataclysmic</span>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>