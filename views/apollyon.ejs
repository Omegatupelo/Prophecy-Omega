<%- include("partials/header") %>

<section class="legend-page legend-abyss">
  <div class="container legend-shell">
    <div class="legend-grid">

      <!-- IMAGE SECTION -->
      <div class="legend-poster-wrap abyss-glow">
        <div class="legend-poster">
          <img src="/images/apollyon.jpg" class="legend-image" alt="Apollyon">
        </div>
      </div>

      <!-- TEXT CONTENT -->
      <div class="legend-copy">
        <div class="legend-badges">
          <span class="legend-badge abyss">Abyss</span>
          <span class="legend-tier">Cataclysmic</span>
        </div>

        <h1>Apollyon</h1>
        <p class="legend-role">King of the Abyss</p>
        <p class="legend-lead">
          Apollyon arrives like corruption given authority. Rot, poison, and ancient ruin
          move with him, and even light feels offended by his presence.
        </p>

        <div class="legend-actions">
          <a class="btn btn-primary" href="/">Return Home</a>
          <a class="btn btn-secondary" href="/characters/beelzebub">View Beelzebub</a>
        </div>

        <div class="legend-panels">

          <!-- DESCRIPTION -->
          <div class="legend-panel">
            <h2>Description</h2>
            <p>
              He looked like a walking insult to creation. His skin was gray-green and
              scaled in places like a serpent that had decided to become a man. Dark mist
              leaked from one arm as it slowly regenerated, and strange orbs drifted around
              his neck like dead planets caught in his gravity. His eyes burned with green
              flame, and his smile carried the satisfaction of a being who enjoyed being hated.
            </p>

            <div class="legend-power-grid">
              <div class="legend-power-card">
                <h3>Corruption</h3>
                <p>Spreads poison, rot, and defilement through every realm he touches.</p>
              </div>
              <div class="legend-power-card">
                <h3>Dominion</h3>
                <p>Claims worlds with the certainty of a conqueror, not the hope of a rebel.</p>
              </div>
              <div class="legend-power-card">
                <h3>Regeneration</h3>
                <p>Dark mist leaks from him as ruined flesh slowly rebuilds itself.</p>
              </div>
              <div class="legend-power-card">
                <h3>Terror</h3>
                <p>His mere presence makes creation feel violated and out of order.</p>
              </div>
            </div>

            <div class="legend-quote">
              “The earth is mine.”
            </div>
          </div>

          <!-- PROFILE -->
          <div class="legend-panel">
            <h2>Profile</h2>
            <div class="legend-profile">
              <div class="legend-row">
                <span class="legend-label">Faction</span>
                <span class="legend-value">Abyss</span>
              </div>
              <div class="legend-row">
                <span class="legend-label">Role</span>
                <span class="legend-value">King of the Abyss</span>
              </div>
              <div class="legend-row">
                <span class="legend-label">Power Theme</span>
                <span class="legend-value">Rot / Poison / Dominion</span>
              </div>
              <div class="legend-row">
                <span class="legend-label">Visual</span>
                <span class="legend-value">Gray-Green Conqueror</span>
              </div>
              <div class="legend-row">
                <span class="legend-label">Background</span>
                <span class="legend-value">Corrupted Battlefield</span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>