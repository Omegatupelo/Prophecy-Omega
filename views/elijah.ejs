<%- include("partials/header") %>

<section class="legend-page legend-heaven">
  <div class="container legend-shell">
    <div class="legend-grid">
      <div class="legend-poster-wrap heaven-glow">
        <div class="legend-poster">
          <div class="legend-coming-soon">Coming Soon</div>
          <div class="legend-placeholder">
            <div class="legend-placeholder-box">
              <div class="legend-placeholder-text">Elijah Image Placeholder</div>
            </div>
          </div>
        </div>
      </div>

      <div class="legend-copy">
        <div class="legend-badges">
          <span class="legend-badge heaven">Heaven</span>
          <span class="legend-tier">Prophetic-Class</span>
        </div>

        <h1>Elijah</h1>
        <p class="legend-role">Prophet of Thunder</p>
        <p class="legend-lead">
          Elijah carries prophetic force, fearless confrontation, and spiritual authority.
          He does not bow before darkness, false power, or compromise.
        </p>

        <div class="legend-actions">
          <a class="btn btn-primary" href="/">Return Home</a>
          <a class="btn btn-secondary" href="/characters/malachi">View Malachi</a>
        </div>

        <div class="legend-panels">
          <div class="legend-panel">
            <h2>Description</h2>
            <p>
              Elijah is a voice of warning, fire, and divine conviction. His presence cuts through fear
              with urgency and confrontation.
            </p>

            <div class="legend-power-grid">
              <div class="legend-power-card"><h3>Prophetic Sight</h3><p>Reads moments beneath appearances.</p></div>
              <div class="legend-power-card"><h3>Thunder Voice</h3><p>Speaks with force and warning.</p></div>
              <div class="legend-power-card"><h3>Fire Call</h3><p>Brings Heaven’s answer into conflict.</p></div>
              <div class="legend-power-card"><h3>Courage</h3><p>Stands firm against corruption.</p></div>
            </div>

            <div class="legend-quote">“Truth does not ask permission before it strikes.”</div>
          </div>

          <div class="legend-panel">
            <h2>Profile</h2>
            <div class="legend-profile">
              <div class="legend-row"><span class="legend-label">Faction</span><span class="legend-value">Heaven</span></div>
              <div class="legend-row"><span class="legend-label">Role</span><span class="legend-value">Prophet of Thunder</span></div>
              <div class="legend-row"><span class="legend-label">Power Theme</span><span class="legend-value">Fire / Warning / Authority</span></div>
              <div class="legend-row"><span class="legend-label">Visual</span><span class="legend-value">Image Coming Soon</span></div>
              <div class="legend-row"><span class="legend-label">Background</span><span class="legend-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

