<%- include("partials/header") %>

<section class="character-page heaven-theme">
  <div class="container character-page-inner">
    <div class="character-cinematic-grid">
      <div class="character-poster">
        <div class="poster-coming-soon">Coming Soon</div>
        <div class="poster-placeholder">
          <div class="poster-placeholder-box">
            <div class="poster-placeholder-text">Elijah Image Placeholder</div>
          </div>
        </div>
      </div>

      <div class="character-copy">
        <div class="faction-badges">
          <span class="faction-badge faction-heaven">Heaven</span>
          <span class="power-badge">Prophetic-Class</span>
        </div>

        <h1>Elijah</h1>
        <p class="character-subrole">Prophet of Thunder</p>
        <p class="character-lead">
          Elijah carries prophetic force, fearless confrontation, and spiritual authority.
          He does not bow easily before false power.
        </p>

        <div class="character-panels">
          <div class="cinematic-panel">
            <h2>Description</h2>
            <p>
              Elijah stands as a voice of warning, fire, and divine conviction.
              His presence cuts through compromise with urgent clarity.
            </p>

            <div class="power-list">
              <div class="power-item"><h3>Prophetic Sight</h3><p>Reads moments beneath appearances.</p></div>
              <div class="power-item"><h3>Fire Call</h3><p>Brings Heaven’s answer into conflict.</p></div>
              <div class="power-item"><h3>Courage</h3><p>Stands firm against corruption.</p></div>
              <div class="power-item"><h3>Thunder Voice</h3><p>Speaks with force and warning.</p></div>
            </div>

            <div class="quote-panel">“Truth does not need permission to strike.”</div>
          </div>

          <div class="cinematic-panel">
            <h2>Profile</h2>
            <div class="profile-list">
              <div class="profile-row"><span class="profile-label">Faction</span><span class="profile-value">Heaven</span></div>
              <div class="profile-row"><span class="profile-label">Role</span><span class="profile-value">Prophet of Thunder</span></div>
              <div class="profile-row"><span class="profile-label">Power Theme</span><span class="profile-value">Fire / Warning / Authority</span></div>
              <div class="profile-row"><span class="profile-label">Visual</span><span class="profile-value">Image Coming Soon</span></div>
              <div class="profile-row"><span class="profile-label">Background</span><span class="profile-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>