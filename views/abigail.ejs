<%- include("partials/header") %>

<section class="character-page heaven-theme">
  <div class="container character-page-inner">
    <div class="character-cinematic-grid">
      <div class="character-poster">
        <div class="poster-coming-soon">Coming Soon</div>
        <div class="poster-placeholder">
          <div class="poster-placeholder-box">
            <div class="poster-placeholder-text">Abigail Image Placeholder</div>
          </div>
        </div>
      </div>

      <div class="character-copy">
        <div class="faction-badges">
          <span class="faction-badge faction-heaven">Heaven</span>
          <span class="power-badge">Grace-Bound</span>
        </div>

        <h1>Abigail</h1>
        <p class="character-subrole">Voice of Discernment</p>
        <p class="character-lead">
          Abigail moves with wisdom, calm force, and spiritual clarity. In a world unraveling under prophecy,
          her presence represents restraint, discernment, and the strength to stand when chaos rises.
        </p>

        <div class="character-panels">
          <div class="cinematic-panel">
            <h2>Description</h2>
            <p>
              Abigail is a stabilizing presence inside a world of divine war. She brings insight, emotional strength,
              and a steadying influence when panic would otherwise rule the moment.
            </p>

            <div class="power-list">
              <div class="power-item">
                <h3>Discernment</h3>
                <p>Sees through confusion and spiritual deception.</p>
              </div>
              <div class="power-item">
                <h3>Presence</h3>
                <p>Brings peace and resolve into unstable moments.</p>
              </div>
              <div class="power-item">
                <h3>Wisdom</h3>
                <p>Balances emotion with insight and direction.</p>
              </div>
              <div class="power-item">
                <h3>Faith</h3>
                <p>Remains grounded under supernatural pressure.</p>
              </div>
            </div>

            <div class="quote-panel">“Not every battle is won by noise. Some are won by clarity.”</div>
          </div>

          <div class="cinematic-panel">
            <h2>Profile</h2>
            <div class="profile-list">
              <div class="profile-row"><span class="profile-label">Faction</span><span class="profile-value">Heaven</span></div>
              <div class="profile-row"><span class="profile-label">Role</span><span class="profile-value">Voice of Discernment</span></div>
              <div class="profile-row"><span class="profile-label">Power Theme</span><span class="profile-value">Wisdom / Stability / Insight</span></div>
              <div class="profile-row"><span class="profile-label">Visual</span><span class="profile-value">Image Coming Soon</span></div>
              <div class="profile-row"><span class="profile-label">Background</span><span class="profile-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>