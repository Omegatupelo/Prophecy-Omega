<%- include("partials/header") %>

<section class="legend-page legend-ancient">
  <div class="container legend-shell">
    <div class="legend-grid">
      <!-- IMAGE SECTION -->
      <div class="legend-poster-wrap heaven-glow">
        <div class="legend-poster">
          <img src="/images/Athena.jpg" class="legend-image" alt="Athena">
        </div>
      </div>
      <div class="legend-poster-wrap ancient-glow">
        <div class="legend-poster">
          <div class="legend-coming-soon">Coming Soon</div>
          <div class="legend-placeholder">
            <div class="legend-placeholder-box">
              <div class="legend-placeholder-text">Athena Image Placeholder</div>
            </div>
          </div>
        </div>
      </div>

      <div class="legend-copy">
        <div class="legend-badges">
          <span class="legend-badge ancient">Ancient Powers</span>
          <span class="legend-tier">Strategic-Class</span>
        </div>

        <h1>Athena</h1>
        <p class="legend-role">Goddess of War and Wisdom</p>
        <p class="legend-lead">
          Athena embodies strategic intelligence, disciplined power, and battlefield wisdom.
          Her force is precise, calculated, and never wasted.
        </p>

        <div class="legend-actions">
          <a class="btn btn-primary" href="/">Return Home</a>
          <a class="btn btn-secondary" href="/characters/isis">View Isis</a>
        </div>

        <div class="legend-panels">
          <div class="legend-panel">
            <h2>Description</h2>
            <p>
              She represents the side of war ruled by reason rather than impulse.
              Athena brings command, clarity, and tactical supremacy into conflict.
            </p>

            <div class="legend-power-grid">
              <div class="legend-power-card"><h3>Tactics</h3><p>Wins battles before they fully begin.</p></div>
              <div class="legend-power-card"><h3>Authority</h3><p>Commands presence without panic.</p></div>
              <div class="legend-power-card"><h3>Wisdom</h3><p>Blends vision with action.</p></div>
              <div class="legend-power-card"><h3>Precision</h3><p>Strikes with purpose, not waste.</p></div>
            </div>

            <div class="legend-quote">“Power guided by wisdom becomes inevitability.”</div>
          </div>

          <div class="legend-panel">
            <h2>Profile</h2>
            <div class="legend-profile">
              <div class="legend-row"><span class="legend-label">Faction</span><span class="legend-value">Ancient Powers</span></div>
              <div class="legend-row"><span class="legend-label">Role</span><span class="legend-value">Goddess of War and Wisdom</span></div>
              <div class="legend-row"><span class="legend-label">Power Theme</span><span class="legend-value">Strategy / Order / Command</span></div>
              <div class="legend-row"><span class="legend-label">Visual</span><span class="legend-value">Image Coming Soon</span></div>
              <div class="legend-row"><span class="legend-label">Background</span><span class="legend-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>