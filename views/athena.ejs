<%- include("partials/header") %>

<section class="character-page ancient-theme">
  <div class="container character-page-inner">
    <div class="character-cinematic-grid">
      <div class="character-poster">
        <div class="poster-coming-soon">Coming Soon</div>
        <div class="poster-placeholder">
          <div class="poster-placeholder-box">
            <div class="poster-placeholder-text">Athena Image Placeholder</div>
          </div>
        </div>
      </div>

      <div class="character-copy">
        <div class="faction-badges">
          <span class="faction-badge faction-ancient">Ancient Powers</span>
          <span class="power-badge">Strategic-Class</span>
        </div>

        <h1>Athena</h1>
        <p class="character-subrole">Goddess of War and Wisdom</p>
        <p class="character-lead">
          Athena embodies strategic intelligence, disciplined power, and battlefield wisdom.
          Her force is precise, calculated, and never wasted.
        </p>

        <div class="character-panels">
          <div class="cinematic-panel">
            <h2>Description</h2>
            <p>
              She represents the side of war ruled by reason rather than impulse. Athena brings clarity,
              command, and tactical supremacy into conflict.
            </p>

            <div class="power-list">
              <div class="power-item"><h3>Tactics</h3><p>Wins battles before they fully begin.</p></div>
              <div class="power-item"><h3>Authority</h3><p>Commands presence without chaos.</p></div>
              <div class="power-item"><h3>Wisdom</h3><p>Blends vision with action.</p></div>
              <div class="power-item"><h3>Precision</h3><p>Strikes with purpose, not waste.</p></div>
            </div>

            <div class="quote-panel">“Power guided by wisdom becomes inevitability.”</div>
          </div>

          <div class="cinematic-panel">
            <h2>Profile</h2>
            <div class="profile-list">
              <div class="profile-row"><span class="profile-label">Faction</span><span class="profile-value">Ancient Powers</span></div>
              <div class="profile-row"><span class="profile-label">Role</span><span class="profile-value">Goddess of War and Wisdom</span></div>
              <div class="profile-row"><span class="profile-label">Power Theme</span><span class="profile-value">Strategy / Order / Command</span></div>
              <div class="profile-row"><span class="profile-label">Visual</span><span class="profile-value">Image Coming Soon</span></div>
              <div class="profile-row"><span class="profile-label">Background</span><span class="profile-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>