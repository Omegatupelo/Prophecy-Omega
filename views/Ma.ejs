<%- include("partials/header") %>

<section class="legend-page legend-ancient">
  <div class="container legend-shell">
    <div class="legend-grid">
      <div class="legend-poster-wrap ancient-glow">
        <div class="legend-poster">
          <div class="legend-coming-soon">Coming Soon</div>
          <div class="legend-placeholder">
            <div class="legend-placeholder-box">
              <div class="legend-placeholder-text">Ma Image Placeholder</div>
            </div>
          </div>
        </div>
      </div>

      <div class="legend-copy">
        <div class="legend-badges">
          <span class="legend-badge ancient">Ancient Powers</span>
          <span class="legend-tier">Order-Class</span>
        </div>

        <h1>Ma</h1>
        <p class="legend-role">Keeper of Order</p>
        <p class="legend-lead">
          Ma represents balance, truth, sacred alignment, and the structure that keeps meaning from collapsing.
        </p>

        <div class="legend-actions">
          <a class="btn btn-primary" href="/">Return Home</a>
          <a class="btn btn-secondary" href="/characters/isis">View Isis</a>
        </div>

        <div class="legend-panels">
          <div class="legend-panel">
            <h2>Description</h2>
            <p>
              In a world unraveling under conflict, Ma stands for the principles that keep order intact.
              She is stillness with authority.
            </p>

            <div class="legend-power-grid">
              <div class="legend-power-card"><h3>Order</h3><p>Stabilizes what chaos tries to break.</p></div>
              <div class="legend-power-card"><h3>Truth</h3><p>Exposes distortion and imbalance.</p></div>
              <div class="legend-power-card"><h3>Judgment</h3><p>Measures what belongs and what does not.</p></div>
              <div class="legend-power-card"><h3>Balance</h3><p>Restores alignment under pressure.</p></div>
            </div>

            <div class="legend-quote">“Without order, even power loses its meaning.”</div>
          </div>

          <div class="legend-panel">
            <h2>Profile</h2>
            <div class="legend-profile">
              <div class="legend-row"><span class="legend-label">Faction</span><span class="legend-value">Ancient Powers</span></div>
              <div class="legend-row"><span class="legend-label">Role</span><span class="legend-value">Keeper of Order</span></div>
              <div class="legend-row"><span class="legend-label">Power Theme</span><span class="legend-value">Truth / Balance / Alignment</span></div>
              <div class="legend-row"><span class="legend-label">Visual</span><span class="legend-value">Image Coming Soon</span></div>
              <div class="legend-row"><span class="legend-label">Background</span><span class="legend-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>