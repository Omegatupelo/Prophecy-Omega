<%- include("partials/header") %>

<section class="character-page ancient-theme">
  <div class="container character-page-inner">
    <div class="character-cinematic-grid">
      <div class="character-poster">
        <div class="poster-coming-soon">Coming Soon</div>
        <div class="poster-placeholder">
          <div class="poster-placeholder-box">
            <div class="poster-placeholder-text">Ma Image Placeholder</div>
          </div>
        </div>
      </div>

      <div class="character-copy">
        <div class="faction-badges">
          <span class="faction-badge faction-ancient">Ancient Powers</span>
          <span class="power-badge">Order-Class</span>
        </div>

        <h1>Ma</h1>
        <p class="character-subrole">Keeper of Order</p>
        <p class="character-lead">
          Ma represents balance, truth, alignment, and sacred order.
          Her force is not noise — it is structure.
        </p>

        <div class="character-panels">
          <div class="cinematic-panel">
            <h2>Description</h2>
            <p>
              In a world collapsing under conflict, Ma stands for the laws that keep meaning from breaking apart.
              She is the still point against corruption and chaos.
            </p>

            <div class="power-list">
              <div class="power-item"><h3>Order</h3><p>Stabilizes what disorder tries to break.</p></div>
              <div class="power-item"><h3>Truth</h3><p>Exposes distortion and imbalance.</p></div>
              <div class="power-item"><h3>Judgment</h3><p>Measures what belongs and what does not.</p></div>
              <div class="power-item"><h3>Balance</h3><p>Restores alignment under pressure.</p></div>
            </div>

            <div class="quote-panel">“Without order, even power loses its meaning.”</div>
          </div>

          <div class="cinematic-panel">
            <h2>Profile</h2>
            <div class="profile-list">
              <div class="profile-row"><span class="profile-label">Faction</span><span class="profile-value">Ancient Powers</span></div>
              <div class="profile-row"><span class="profile-label">Role</span><span class="profile-value">Keeper of Order</span></div>
              <div class="profile-row"><span class="profile-label">Power Theme</span><span class="profile-value">Truth / Balance / Alignment</span></div>
              <div class="profile-row"><span class="profile-label">Visual</span><span class="profile-value">Image Coming Soon</span></div>
              <div class="profile-row"><span class="profile-label">Background</span><span class="profile-value">Placeholder Active</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>